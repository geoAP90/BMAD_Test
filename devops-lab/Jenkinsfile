pipeline {
    agent any

    environment {
        SONAR_PROJECT_KEY  = 'Insurance-Accelerator'
        SONAR_PROJECT_NAME = 'Insurance Accelerator'
        NEXUS_URL          = 'http://nexus-devops:8081'
        NEXUS_PYPI_REPO    = 'pypi-releases'
        APP_NAME           = 'insurance-accelerator'
        APP_VERSION        = "1.0.${BUILD_NUMBER}"
        PYTHON             = 'python3'
    }

    stages {

        // ── 1. Checkout ───────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "Checking out from GitHub..."
                checkout scm
            }
        }

        // ── 2. Setup Python environment ───────────────────────────────────────
        stage('Setup Python') {
            steps {
                sh '''
                    set -e
                    python3 --version

                    # Install pip if needed
                    python3 -m ensurepip --upgrade 2>/dev/null || true

                    # Install dependencies
                    if [ -f requirements.txt ]; then
                        pip3 install -r requirements.txt --break-system-packages
                    else
                        pip3 install fastapi uvicorn pytest pytest-asyncio \
                            httpx pydantic coverage pytest-cov \
                            build wheel twine --break-system-packages
                    fi

                    # Install sonar-scanner
                    pip3 install pysonar-scanner 2>/dev/null || true

                    echo "Python environment ready."
                '''
            }
        }

        // ── 3. Run Tests (pytest + unittest) ─────────────────────────────────
        stage('Test') {
            steps {
                sh '''
                    set -e

                    # Make src/ importable so conftest.py can do "from main import app"
                    export PYTHONPATH="${WORKSPACE}/src:${WORKSPACE}:${PYTHONPATH}"

                    if [ -d tests ] || [ -d test ]; then
                        echo "Running pytest with coverage..."
                        python3 -m pytest tests/ -v \
                            --cov=src \
                            --cov-report=xml:coverage.xml \
                            --cov-report=term-missing \
                            --junitxml=test-results.xml \
                            2>&1 || python3 -m pytest tests/ -v \
                            --cov=. \
                            --cov-report=xml:coverage.xml \
                            --junitxml=test-results.xml
                    else
                        echo "No tests directory found — skipping tests."
                        echo '<?xml version="1.0"?><testsuites></testsuites>' > test-results.xml
                        echo '<?xml version="1.0"?><coverage></coverage>' > coverage.xml
                    fi
                '''
            }
        }

        // ── 4. SonarQube Analysis ─────────────────────────────────────────────
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh """
                        export PYTHONPATH="${WORKSPACE}/src:${WORKSPACE}:\${PYTHONPATH}"
                        # Write sonar properties
                        cat > sonar-project.properties << EOF
sonar.projectKey=${SONAR_PROJECT_KEY}
sonar.projectName=${SONAR_PROJECT_NAME}
sonar.projectVersion=${APP_VERSION}
sonar.sources=src
sonar.tests=tests
sonar.python.coverage.reportPaths=coverage.xml
sonar.python.xunit.reportPath=test-results.xml
sonar.sourceEncoding=UTF-8
sonar.language=py
EOF

                        # Run sonar-scanner
                        sonar-scanner \
                            -Dsonar.host.url=\${SONAR_HOST_URL} \
                            -Dsonar.token=\${SONAR_AUTH_TOKEN} \
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                            -Dsonar.projectName="${SONAR_PROJECT_NAME}" \
                            -Dsonar.projectVersion=${APP_VERSION} \
                            -Dsonar.sources=src \
                            -Dsonar.tests=tests \
                            -Dsonar.python.coverage.reportPaths=coverage.xml \
                            -Dsonar.python.xunit.reportPath=test-results.xml \
                            -Dsonar.language=py \
                        || echo "sonar-scanner not found, trying python sonar..."
                    """
                }
            }
        }

        // ── 5. Quality Gate ───────────────────────────────────────────────────
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        // ── 6. Package as wheel ───────────────────────────────────────────────
        stage('Package') {
            steps {
                sh """
                    set -e

                    # Create setup.py if not present
                    if [ ! -f setup.py ] && [ ! -f pyproject.toml ]; then
                        cat > setup.py << 'SETUP'
from setuptools import setup, find_packages
setup(
    name='insurance-accelerator',
    version='${APP_VERSION}',
    packages=find_packages(),
    install_requires=[
        'fastapi',
        'uvicorn',
        'pydantic',
    ],
)
SETUP
                    fi

                    # Build wheel
                    python3 -m build --wheel --outdir dist/ 2>/dev/null || \
                    python3 setup.py bdist_wheel --dist-dir dist/ 2>/dev/null || \
                    (mkdir -p dist && zip -r dist/insurance_accelerator-${APP_VERSION}.zip src/ && echo "Created zip package")

                    ls -la dist/
                    echo "Package built: ${APP_NAME} v${APP_VERSION}"
                """
            }
        }

        // ── 7. Deploy to Nexus PyPI ───────────────────────────────────────────
        stage('Deploy to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-credentials',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh """
                        set -e

                        NEXUS_PYPI_URL="${NEXUS_URL}/repository/${NEXUS_PYPI_REPO}/"

                        # Try twine upload first
                        if command -v twine &>/dev/null; then
                            twine upload \
                                --repository-url "\${NEXUS_PYPI_URL}" \
                                --username "\${NEXUS_USER}" \
                                --password "\${NEXUS_PASS}" \
                                --skip-existing \
                                dist/* \
                            && echo "Uploaded via twine" && exit 0
                        fi

                        # Fallback: curl upload each file
                        for f in dist/*; do
                            filename=\$(basename "\$f")
                            echo "Uploading \$filename to Nexus..."
                            curl -u "\${NEXUS_USER}:\${NEXUS_PASS}" \
                                 --upload-file "\$f" \
                                 "\${NEXUS_PYPI_URL}\$filename" \
                            && echo "Uploaded: \$filename"
                        done

                        echo "Deploy complete: \${NEXUS_PYPI_URL}"
                    """
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline finished — Build #${BUILD_NUMBER}"
            deleteDir()
        }
        success {
            echo "SUCCESS: ${APP_NAME} v${APP_VERSION} tested, scanned, and deployed."
        }
        failure {
            echo "FAILED: Check stage logs above."
        }
    }
}
