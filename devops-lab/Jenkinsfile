pipeline {
    agent any

    environment {
        SONAR_PROJECT_KEY  = 'Insurance-Accelerator'
        SONAR_PROJECT_NAME = 'Insurance Accelerator'
        NEXUS_URL          = 'http://nexus-devops:8081'
        NEXUS_PYPI_REPO    = 'pypi-releases'
        APP_NAME           = 'insurance-accelerator'
        APP_VERSION        = "1.0.${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Checking out from GitHub..."
                checkout scm
            }
        }

        stage('Setup Python') {
            steps {
                sh '''
                    set -e
                    python3 --version
                    python3 -m ensurepip --upgrade 2>/dev/null || true
                    if [ -f requirements.txt ]; then
                        pip3 install -r requirements.txt --break-system-packages
                    else
                        pip3 install fastapi uvicorn pytest pytest-asyncio \
                            httpx pydantic coverage pytest-cov \
                            build wheel twine --break-system-packages
                    fi
                    echo "Python environment ready."
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    set -e
                    export PYTHONPATH="${WORKSPACE}/src:${WORKSPACE}:${PYTHONPATH}"
                    if [ -d tests ]; then
                        echo "Running pytest with coverage..."
                        python3 -m pytest tests/ -v \
                            --cov=src \
                            --cov-report=xml:coverage.xml \
                            --cov-report=term-missing \
                            --junitxml=test-results.xml
                    else
                        echo "No tests directory — skipping."
                        echo '<?xml version="1.0"?><testsuites></testsuites>' > test-results.xml
                        echo '<?xml version="1.0"?><coverage></coverage>' > coverage.xml
                    fi
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh """
                        export PYTHONPATH="${WORKSPACE}/src:${WORKSPACE}:\${PYTHONPATH}"
                        sonar-scanner \
                            -Dsonar.host.url=\${SONAR_HOST_URL} \
                            -Dsonar.token=\${SONAR_AUTH_TOKEN} \
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                            -Dsonar.projectName="${SONAR_PROJECT_NAME}" \
                            -Dsonar.projectVersion=${APP_VERSION} \
                            -Dsonar.sources=src \
                            -Dsonar.tests=tests \
                            -Dsonar.python.coverage.reportPaths=coverage.xml \
                            -Dsonar.python.xunit.reportPath=test-results.xml \
                            -Dsonar.language=py
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Package') {
            steps {
                sh """
                    set -e
                    if [ ! -f setup.py ] && [ ! -f pyproject.toml ]; then
                        cat > setup.py << 'SETUP'
from setuptools import setup, find_packages
setup(
    name='insurance-accelerator',
    version='${APP_VERSION}',
    packages=find_packages(),
    install_requires=['fastapi', 'uvicorn', 'pydantic'],
)
SETUP
                    fi
                    python3 -m build --wheel --outdir dist/ 2>/dev/null || \
                    python3 setup.py bdist_wheel --dist-dir dist/
                    ls -la dist/
                    echo "Package built: ${APP_NAME} v${APP_VERSION}"
                """
            }
        }

        stage('Deploy to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-credentials',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh """
                        set -e
                        NEXUS_PYPI_URL="${NEXUS_URL}/repository/${NEXUS_PYPI_REPO}/"
                        echo "Uploading to Nexus: \${NEXUS_PYPI_URL}"
                        twine upload \
                            --repository-url "\${NEXUS_PYPI_URL}" \
                            --username "\${NEXUS_USER}" \
                            --password "\${NEXUS_PASS}" \
                            --verbose \
                            dist/*.whl
                        echo "Deploy complete."
                    """
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline finished — Build #${BUILD_NUMBER}"
            deleteDir()
        }
        success {
            echo "SUCCESS: ${APP_NAME} v${APP_VERSION} built, tested, scanned, deployed."
        }
        failure {
            echo "FAILED: Check stage logs above."
        }
    }
}
